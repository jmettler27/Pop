    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.20",
    "@mui/material": "^5.15.20",
    "@mui/system": "^5.15.20",
    "@mui/x-data-grid": "^7.7.1",
    "@uiw/react-color-sketch": "^2.3.0",
    "chart.js": "^4.4.3",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
