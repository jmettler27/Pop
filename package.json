    "next": "^16.1.1",
    "next-auth": "^4.24.13",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.2.6",
    "react-firebase-hooks": "^5.1.1",
    "react-intl": "^10.0.0",
    "sass": "^1.77.6",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.5.0",
    "eslint-config-next": "^15.2.1",
